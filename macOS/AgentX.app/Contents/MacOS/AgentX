#!/bin/bash

# AgentX Electron Launcher
# Starts backend and frontend servers, then launches Electron

APP_DIR="$(cd "$(dirname "$0")/../Resources" && pwd)"
NODE_BIN="$APP_DIR/node/bin/node"
NPM_BIN="$APP_DIR/node/bin/npm"
PID_FILE="/tmp/agentx-electron.pid"
LOG_DIR="$HOME/Library/Logs/AgentX"
LOG_FILE="$LOG_DIR/launcher.log"

# Create log directory
mkdir -p "$LOG_DIR"

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" | tee -a "$LOG_FILE"
}

log "🚀 AgentX Launcher Starting..."
log "📁 App Directory: $APP_DIR"

# Check if already running
if [ -f "$PID_FILE" ]; then
    OLD_PID=$(cat "$PID_FILE")
    if ps -p "$OLD_PID" > /dev/null 2>&1; then
        log "⚠️ AgentX already running (PID: $OLD_PID)"
        # Just focus the existing window
        osascript -e 'tell application "System Events" to tell process "AgentX" to set frontmost to true' 2>/dev/null || true
        exit 0
    else
        rm "$PID_FILE"
    fi
fi

# Verify Node.js works
if [ ! -f "$NODE_BIN" ]; then
    log "❌ Node binary not found at: $NODE_BIN"
    osascript -e 'display alert "AgentX Error" message "Node.js binary missing. Please reinstall AgentX."'
    exit 1
fi

# Set environment
export PATH="$APP_DIR/node/bin:$PATH"
export AGENTX_STANDALONE="1"
export NODE_ENV="development"

cd "$APP_DIR" || exit 1

# Install dependencies if needed
if [ ! -d "node_modules" ]; then
    log "📦 Installing root dependencies..."
    "$NPM_BIN" install >> "$LOG_FILE" 2>&1
fi

if [ ! -d "frontend/node_modules" ]; then
    log "📦 Installing frontend dependencies..."
    cd frontend && "$NPM_BIN" install >> "$LOG_FILE" 2>&1 &
    cd "$APP_DIR"
fi

if [ ! -d "backend/node_modules" ]; then
    log "📦 Installing backend dependencies..."
    cd backend && "$NPM_BIN" install >> "$LOG_FILE" 2>&1 &
    cd "$APP_DIR"
fi

# Start backend server
log "🔧 Starting backend server..."
"$NODE_BIN" backend/server.js >> "$LOG_FILE" 2>&1 &
echo $! > /tmp/agentx-backend.pid
BACKEND_PID=$!
log "   Backend PID: $BACKEND_PID"

# Wait for backend
log "⏳ Waiting for backend (10s)..."
sleep 10

# Start frontend dev server
log "🎨 Starting frontend server..."
cd frontend
"$NPM_BIN" run dev >> "$LOG_FILE" 2>&1 &
echo $! > /tmp/agentx-frontend.pid
FRONTEND_PID=$!
cd "$APP_DIR"
log "   Frontend PID: $FRONTEND_PID"

# Wait for frontend
log "⏳ Waiting for frontend (15s)..."
sleep 15

# Start Electron
log "⚛️ Starting Electron..."
"$NODE_BIN" node_modules/.bin/electron electron-main.cjs >> "$LOG_FILE" 2>&1 &
echo $! > "$PID_FILE"
ELECTRON_PID=$!
log "   Electron PID: $ELECTRON_PID"

log "✨ AgentX started successfully!"
log "   Dashboard: http://localhost:5173"

# Keep script running and monitor processes
while true; do
    if ! ps -p "$ELECTRON_PID" > /dev/null 2>&1; then
        log "🛑 Electron stopped, shutting down servers..."
        kill "$BACKEND_PID" "$FRONTEND_PID" 2>/dev/null || true
        rm -f "$PID_FILE" /tmp/agentx-backend.pid /tmp/agentx-frontend.pid
        exit 0
    fi
    sleep 2
done
