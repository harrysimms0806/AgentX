{
  "name": "agentx",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "dev:daemon": "npm run dev -w apps/daemon",
    "dev:ui": "npm run dev -w apps/ui"
  },
  "devDependencies": {
    "turbo": "^2.8.10",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
